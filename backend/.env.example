# Copy this file to ".env" and fill in your real values.

# Server port
PORT=5000

# --- Email (SMTP) ---
# Gmail: enable 2FA then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=your_email@gmail.com

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/al-rahma
# Atlas:  mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net/al-rahma
MONGO_URI=mongodb+srv://<DB_USER>:<DB_PASS>@cluster0.xxxx.mongodb.net/al-rahma?appName=Cluster0

# Secret used to sign JWT tokens (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend URL allowed by CORS (your React dev server)
CLIENT_URL=http://localhost:5173

# --- Scheduled jobs (cron) ---
# Secret that protects /api/cron/* endpoints. Vercel Cron sends it automatically
# as "Authorization: Bearer <CRON_SECRET>". Use a long random string.
CRON_SECRET=change_this_to_a_long_random_secret
# How many days before expiry the renewal reminder email is sent (default 3).
RENEWAL_REMINDER_DAYS=3

# --- Rate limiting (OPTIONAL) ---
# Leave blank to use per-instance in-memory limits (fine for low traffic).
# Set to a Redis connection string (e.g. Upstash) to share limits globally
# across all serverless instances. Requires: npm i ioredis rate-limit-redis
# REDIS_URL=rediss://default:<password>@<host>:<port>

# ---------------------------------------------------------------------------
# Stripe (cards + Apple Pay + Google Pay, monthly subscription) — dashboard.stripe.com
# ---------------------------------------------------------------------------
# Developers > API keys — Secret key (use the test key until you go live)
STRIPE_SECRET_KEY=
# Developers > Webhooks — the signing secret for your webhook endpoint
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# PayPal (international) — from developer.paypal.com > Apps & Credentials
# ---------------------------------------------------------------------------
PAYPAL_MODE=sandbox            # sandbox | live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Apps & Credentials > your app > Webhooks — needed to verify PayPal webhooks
PAYPAL_WEBHOOK_ID=
