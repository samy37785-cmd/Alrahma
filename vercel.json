{
  "version": 2,
  "installCommand": "npm install && npm install --prefix server",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 30,
      "memory": 512
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/(.*)",       "destination": "/index.html"   }
  ]
}
