# Copy this file to ".env" and fill in your real values.

# Server port
PORT=5000

# --- Email (SMTP) ---
# Gmail: enable 2FA then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=your_email@gmail.com

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/al-rahma
# Atlas:  mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net/al-rahma
MONGO_URI=mongodb+srv://mahmoud:01016054663@cluster0.xhav5li.mongodb.net/?appName=Cluster0

# Secret used to sign JWT tokens (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend URL allowed by CORS (your React dev server)
CLIENT_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# PayMob (cards + Vodafone Cash / wallets + Fawry) — from your PayMob dashboard
# ---------------------------------------------------------------------------
# Account > API Key
PAYMOB_API_KEY=
# Currency your PayMob account settles in (usually EGP)
PAYMOB_CURRENCY=EGP
# Plan prices are in EUR. If PAYMOB_CURRENCY is EGP, the amount is converted
# using this rate (1 EUR = X EGP). Update it to your bank/gateway rate.
PAYMOB_EUR_TO_EGP=55
# Developers > Payment Integrations — one id per payment method
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_INTEGRATION_ID_WALLET=
PAYMOB_INTEGRATION_ID_FAWRY=
# Developers > iframes — the iframe id used to render the card form
PAYMOB_IFRAME_ID=
# Used to verify webhook callbacks (Account > HMAC)
PAYMOB_HMAC_SECRET=

# ---------------------------------------------------------------------------
# PayPal (international) — from developer.paypal.com > Apps & Credentials
# ---------------------------------------------------------------------------
PAYPAL_MODE=sandbox            # sandbox | live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
