# Frontend env — copy to ".env" for local development.
# Vite only exposes variables prefixed with VITE_.
#
# ── Local development ────────────────────────────────────────────────────────
# Points at the local Express server (Vite proxies /api → localhost:5000).
VITE_API_URL=http://localhost:5000/api

# ── Production (Vercel) ──────────────────────────────────────────────────────
# Set VITE_API_URL in the Vercel project's Environment Variables dashboard to
# your Render backend URL so the SPA calls the right server.
# Example:
#   VITE_API_URL=https://alrahma-1.onrender.com/api
#
# Without this, the SPA falls back to the relative path "/api", which will not
# resolve to the Render backend on Vercel.

# GA4 measurement ID (e.g. G-XXXXXXXXXX). Leave blank to disable analytics.
VITE_GA_ID=

# Google Sign-In client ID (same value as backend GOOGLE_CLIENT_ID).
VITE_GOOGLE_CLIENT_ID=

# Microsoft Clarity project ID (clarity.microsoft.com). Leave blank to disable.
VITE_CLARITY_ID=

# Tawk.to live-chat widget IDs (tawk.to dashboard > Administration > Property).
VITE_TAWK_PROPERTY_ID=
VITE_TAWK_WIDGET_ID=

# YouTube video ID used in the Hero "Watch demo" modal.
VITE_DEMO_VIDEO_ID=

# Daily.co domain for live-class embed detection (e.g. alrahma.daily.co).
VITE_DAILY_DOMAIN=
