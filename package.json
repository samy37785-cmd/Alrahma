{
  "name": "al-rahma-academy",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Al-Rahma Academy — Learn the Holy Quran Online (React)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "npm --prefix server run dev",
    "start:all": "concurrently -n server,client -c green,cyan \"npm run server\" \"npm run dev\"",
    "setup": "npm install && npm --prefix server install",
    "start": "npm run start:all"
  },
  "dependencies": {
    "axios": "^1.17.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^10.0.3",
    "vite": "^5.4.11"
  }
}
