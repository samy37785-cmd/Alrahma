# Copy this file to ".env" and fill in your real values.

# Server port
PORT=5000

# --- Email (SMTP) ---
# Gmail: enable 2FA then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=your_email@gmail.com

# MongoDB connection string
# Local:  mongodb://127.0.0.1:27017/al-rahma
# Atlas:  mongodb+srv://<user>:<pass>@cluster0.xxxx.mongodb.net/al-rahma
MONGO_URI=mongodb+srv://<DB_USER>:<DB_PASS>@cluster0.xxxx.mongodb.net/al-rahma?appName=Cluster0

# Secret used to sign JWT tokens (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend URL allowed by CORS (your React dev server)
CLIENT_URL=http://localhost:5173

# --- Scheduled jobs (cron) ---
# Secret that protects /api/cron/* endpoints. Vercel Cron sends it automatically
# as "Authorization: Bearer <CRON_SECRET>". Use a long random string.
CRON_SECRET=change_this_to_a_long_random_secret
# How many days before expiry the renewal reminder email is sent (default 3).
RENEWAL_REMINDER_DAYS=3

# --- Rate limiting (OPTIONAL) ---
# Leave blank to use per-instance in-memory limits (fine for low traffic).
# Set to a Redis connection string (e.g. Upstash) to share limits globally
# across all serverless instances. Requires: npm i ioredis rate-limit-redis
# REDIS_URL=rediss://default:<password>@<host>:<port>

# ---------------------------------------------------------------------------
# Stripe (cards + Apple Pay + Google Pay, monthly subscription) — dashboard.stripe.com
# ---------------------------------------------------------------------------
# Developers > API keys — Secret key (use the test key until you go live)
STRIPE_SECRET_KEY=
# Developers > Webhooks — the signing secret for your webhook endpoint
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# PayPal (international) — from developer.paypal.com > Apps & Credentials
# ---------------------------------------------------------------------------
PAYPAL_MODE=sandbox            # sandbox | live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Apps & Credentials > your app > Webhooks — needed to verify PayPal webhooks
PAYPAL_WEBHOOK_ID=

# ---------------------------------------------------------------------------
# Admin Dashboard (Zero-Trust)
# ---------------------------------------------------------------------------
# Separate JWT secrets for admin tokens — MUST differ from JWT_SECRET above.
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ADMIN_JWT_ACCESS_SECRET=change_this_to_a_64_byte_random_hex_string

# AES-256 key for encrypting admin TOTP secrets and SystemConfig sensitive values.
# Must be exactly 64 hex characters (32 bytes = 256 bits).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_ENCRYPTION_KEY=change_this_to_a_64_char_hex_string

# IP whitelist for /api/v1/admin/* (comma-separated IPs or CIDR ranges).
# Leave blank to allow all IPs (fine for local dev; restrict in production).
# Example: ADMIN_IP_WHITELIST=1.2.3.4,10.0.0.0/8,::1
ADMIN_IP_WHITELIST=

# ---------------------------------------------------------------------------
# Google Sign-In (Social Login)
# ---------------------------------------------------------------------------
# Create a project at console.cloud.google.com → APIs & Services → Credentials
# Create OAuth 2.0 Client ID (Web application). Add your domain to Authorized origins.
GOOGLE_CLIENT_ID=

# ---------------------------------------------------------------------------
# Frontend-only env vars (set in frontend/.env or Vercel env UI with VITE_ prefix)
# ---------------------------------------------------------------------------
# VITE_GOOGLE_CLIENT_ID=          # Same value as GOOGLE_CLIENT_ID above
# VITE_DEMO_VIDEO_ID=             # YouTube video ID for the Hero "Watch demo" modal
# VITE_CLARITY_ID=                # Microsoft Clarity project ID (clarity.microsoft.com)
# VITE_TAWK_PROPERTY_ID=          # Tawk.to property ID
# VITE_TAWK_WIDGET_ID=            # Tawk.to widget/chat ID
# VITE_DAILY_DOMAIN=              # Your Daily.co domain (e.g. alrahma.daily.co) — used to detect embedded rooms
